def load_basis(W_, V_, Q_, map_u_, map_p_):
    """Read the mean field and POD modes from the BP4 basis file."""

    mpi_print("Loading ROM basis...")

    u_fn = Function(V_)
    p_fn = Function(Q_)

    try:
        adios4dolfinx.read_function(BASIS_BP, u_fn, time=-1.0, name="u", engine="BP4")
        adios4dolfinx.read_function(BASIS_BP, p_fn, time=-1.0, name="p", engine="BP4")
        mean_time_used = -1.0

    except Exception:
        adios4dolfinx.read_function(BASIS_BP, u_fn, time=0.0, name="u", engine="BP4")
        adios4dolfinx.read_function(BASIS_BP, p_fn, time=0.0, name="p", engine="BP4")
        mean_time_used = 0.0

    u_fn.x.scatter_forward()
    p_fn.x.scatter_forward()

    w_mean_fn = Function(W_)
    w_mean_fn.x.array[map_u_] = u_fn.x.array
    w_mean_fn.x.array[map_p_] = p_fn.x.array
    w_mean_fn.x.scatter_forward()

    wbasis_mean = w_mean_fn.x.array.copy()

    all_times = adios4dolfinx.read_timestamps(BASIS_BP, comm, "u", engine="BP4")

    if mean_time_used < 0.0:
        mode_times = sorted([tt for tt in all_times if tt >= 0.0])
    else:
        mode_times = sorted([tt for tt in all_times if tt > 0.0])

    n_available = len(mode_times)
    r_used = min(rsize, n_available)

    mpi_print(f"  Mean read at t = {mean_time_used}")
    mpi_print(f"  Available modes = {n_available}")
    mpi_print(f"  Modes used = {r_used}")

    if r_used <= 0:
        raise RuntimeError("No POD modes were found in the basis file.")

    N_dofs = len(wbasis_mean)
    upbasis = np.zeros((N_dofs, r_used), dtype=np.float64)

    for k, tt in enumerate(mode_times[:r_used]):
        adios4dolfinx.read_function(BASIS_BP, u_fn, time=tt, name="u", engine="BP4")
        adios4dolfinx.read_function(BASIS_BP, p_fn, time=tt, name="p", engine="BP4")

        u_fn.x.scatter_forward()
        p_fn.x.scatter_forward()

        w_mode = Function(W_)
        w_mode.x.array[map_u_] = u_fn.x.array
        w_mode.x.array[map_p_] = p_fn.x.array
        w_mode.x.scatter_forward()

        upbasis[:, k] = w_mode.x.array[:]

        mpi_print(f"  Loaded mode {k + 1}/{r_used} from t = {tt}")

    return wbasis_mean, upbasis, r_used


def build_petsc_basis(upbasis, mesh_):
    """Build the PETSc dense matrix containing the reduced basis."""

    Ndofs, r_used = upbasis.shape

    Phi = PETSc.Mat().createDense([Ndofs, r_used], comm=mesh_.comm)
    Phi.setUp()

    rows = np.arange(Ndofs, dtype=PETSc.IntType)

    for j in range(r_used):
        Phi.setValues(rows, [PETSc.IntType(j)], upbasis[:, j])

    Phi.assemble()

    return Phi


def solve_reduced_galerkin_petsc(A, b, Phi, w_mean_fun, wbasis_mean, upbasis):
    """Solve the Galerkin-projected reduced system using PETSc products."""

    APhi = A.matMult(Phi)
    K_rom_mat = Phi.transposeMatMult(APhi)

    Awmean = b.duplicate()
    A.mult(w_mean_fun.x.petsc_vec, Awmean)

    b_tilde = b.duplicate()
    b_tilde.waxpy(-1.0, Awmean, b)

    rhs_vec = Phi.createVecRight()
    Phi.multTranspose(b_tilde, rhs_vec)

    K_rom = K_rom_mat.getDenseArray().copy()
    rhs_r = rhs_vec.getArray(readonly=True).copy()

    K_rom = K_rom + rom_regularization * np.eye(K_rom.shape[0])

    alpha_rom = np.linalg.solve(K_rom, rhs_r)
    uvec = wbasis_mean + upbasis @ alpha_rom

    return uvec


# =============================================================================
# ROM solver
# =============================================================================

def solve_rom(
    W_,
    V_,
    Q_,
    map_u_,
    map_p_,
    bcs_u_,
    FinalTime_,
    dt_,
    theta_,
    mesh_,
    VisSpace_,
    u_inlet_,
    u_in,
):
    """Run the transient ROM simulation."""

    w = ufl.TrialFunction(W_)
    z = ufl.TestFunction(W_)

    y1_old = Function(W_)
    y1_oold = Function(W_)
    y1_ooold = Function(W_)

    y2_old = Function(W_)
    y2_oold = Function(W_)
    y2_ooold = Function(W_)

    w_old = Function(W_)
    w_oold = Function(W_)
    w_ooold = Function(W_)
    w_i = Function(W_)
    w_inc = Function(W_)

    for f in [
        y1_old,
        y1_oold,
        y1_ooold,
        y2_old,
        y2_oold,
        y2_ooold,
        w_old,
        w_oold,
        w_ooold,
        w_i,
        w_inc,
    ]:
        f.x.array[:] = 0.0
        f.x.scatter_forward()

    u_vis = Function(V_)
    u_vis.name = "velocity"

    p_vis = Function(Q_)
    p_vis.name = "pressure"

    us1_vis = Function(V_)
    us1_vis.name = "velocity_subscale1"

    us2_vis = Function(V_)
    us2_vis.name = "velocity_subscale2"

    visco_vis = Function(VisSpace_)
    visco_vis.name = "viscosity"

    if rank == 0:
        if RESULTS_DIR.exists():
            shutil.rmtree(RESULTS_DIR)

        RESULTS_DIR.mkdir(parents=True, exist_ok=True)
        print(f"Writing ROM outputs to: {RESULTS_DIR}")

    comm.Barrier()

    chi_file = XDMFFile(comm, RESULTS_DIR / "actuator_disk_indicator.xdmf", "w")
    chi_file.write_mesh(mesh_)
    chi_file.write_function(chi_ad, 0.0)
    chi_file.close()

    ufile = XDMFFile(comm, RESULTS_DIR / "velocity.xdmf", "w")
    pfile = XDMFFile(comm, RESULTS_DIR / "pressure.xdmf", "w")
    us1file = XDMFFile(comm, RESULTS_DIR / "velocity_subscale1.xdmf", "w")
    us2file = XDMFFile(comm, RESULTS_DIR / "velocity_subscale2.xdmf", "w")
    vfile = XDMFFile(comm, RESULTS_DIR / "viscosity.xdmf", "w")

    for output_file in [ufile, pfile, us1file, us2file, vfile]:
        output_file.write_mesh(mesh_)

    adios4dolfinx.write_mesh(RESULTS_BP, mesh_, engine="BP4")
    adios4dolfinx.write_meshtags(
        RESULTS_BP,
        mesh_,
        ft,
        meshtag_name="facet_tags",
        engine="BP4",
    )
    adios4dolfinx.write_meshtags(
        RESULTS_BP,
        mesh_,
        ct,
        meshtag_name="cell_tags",
        engine="BP4",
    )

    wbasis_mean, upbasis, r_used = load_basis(W_, V_, Q_, map_u_, map_p_)
    Phi = build_petsc_basis(upbasis, mesh_)

    w_mean_fun = Function(W_)
    w_mean_fun.x.array[:] = wbasis_mean
    w_mean_fun.x.scatter_forward()

    for f in [w_i, w_old, w_oold, w_ooold]:
        f.x.array[:] = wbasis_mean
        f.x.scatter_forward()

    next_xdmf_time = 0.0
    next_bp_time = init_snap
    time_tol = max(1.0e-12, 1.0e-9 * dt_)

    expected_snapshots = (
        int(np.floor((FinalTime_ - init_snap) / inte_snap)) + 1
        if inte_snap > 0
        else 0
    )

    mpi_print(f"ROM size requested/used = {rsize}/{r_used}")
    mpi_print(f"Expected BP snapshots = {max(expected_snapshots, 0)}")
    mpi_print(f"BP save interval = {inte_snap} s")
    mpi_print(f"XDMF save interval = {inte_xdmf} s")

    time = 0.0
    step = 0

    while time <= FinalTime_ + time_tol:
        mpi_print(f"---- Time instant = {time:g} ----")

        u_inlet_.interpolate(u_in)
        u_inlet_.x.scatter_forward()

        Ftt = (theta_[1] / dt_) * rho * w_old
        Fttt = (theta_[2] / dt_) * rho * w_oold
        Ftttt = (theta_[3] / dt_) * rho * w_ooold

        L2_error_u = 1.0
        it = 0

        while L2_error_u > tol_NL and it < maxiter_NL:
            it += 1

            visco = Constant(mesh_, PETSc.ScalarType(m)) if n == 1 else Viscosity(w_i, n, m)

            FL = VarFormNS(
                w,
                w_i,
                z,
                w_old,
                w_oold,
                w_ooold,
                y1_old,
                y1_oold,
                y1_ooold,
                y2_old,
                y2_oold,
                y2_ooold,
                visco,
                dt_,
            )

            Ft = (theta_[0] / dt_) * rho * w

            Du = ufl.dot(
                ufl.as_vector(
                    (
                        Ft[0] + Ftt[0] + Fttt[0] + Ftttt[0],
                        Ft[1] + Ftt[1] + Fttt[1] + Ftttt[1],
                        0.0,
                    )
                ),
                z,
            ) * dx

            F = FL + Du

            a_form = fem.form(ufl.lhs(F))
            L_form = fem.form(ufl.rhs(F))

            A = fem_petsc.assemble_matrix(a_form, bcs=bcs_u_)
            A.assemble()

            b = fem_petsc.assemble_vector(L_form)
            fem_petsc.apply_lifting(b, [a_form], [bcs_u_])
            b.ghostUpdate(
                addv=PETSc.InsertMode.ADD,
                mode=PETSc.ScatterMode.REVERSE,
            )
            fem_petsc.set_bc(b, bcs_u_)

            uvec = solve_reduced_galerkin_petsc(
                A,
                b,
                Phi,
                w_mean_fun,
                wbasis_mean,
                upbasis,
            )

            w_inc.x.array[:] = np.ascontiguousarray(uvec)
            w_inc.x.scatter_forward()

            u_inc_expr, _ = ufl.split(w_inc)
            u_i_expr, _ = ufl.split(w_i)

            L2_error_local = fem.assemble_scalar(
                fem.form(
                    ufl.inner(
                        u_inc_expr - u_i_expr,
                        u_inc_expr - u_i_expr,
                    ) * dx
                )
            )
            L2_error_u = comm.allreduce(L2_error_local, op=MPI.SUM)

            mpi_print(f"  it = {it}: L2-error-NL = {L2_error_u:g}")

            w_i.x.array[:] = alpha_U * w_inc.x.array + (1.0 - alpha_U) * w_i.x.array
            w_i.x.scatter_forward()

            if it == maxiter_NL:
                mpi_print("  Warning: nonlinear ROM iteration did not converge.")

        y1_new = project(
            Subscales1(w_inc, w_i, dt_, visco)
            + Subscalesd(w_inc, w_i, dt_, y1_old, y1_oold, y1_ooold, visco),
            W_,
        )

        y2_new = project(
            Subscales2(w_inc, w_i, dt_, visco)
            + Subscalesd(w_inc, w_i, dt_, y2_old, y2_oold, y2_ooold, visco),
            W_,
        )

        y1_ooold.x.array[:] = y1_oold.x.array
        y1_ooold.x.scatter_forward()

        y1_oold.x.array[:] = y1_old.x.array
        y1_oold.x.scatter_forward()

        y1_old.x.array[:] = y1_new.x.array
        y1_old.x.scatter_forward()

        y2_ooold.x.array[:] = y2_oold.x.array
        y2_ooold.x.scatter_forward()

        y2_oold.x.array[:] = y2_old.x.array
        y2_oold.x.scatter_forward()

        y2_old.x.array[:] = y2_new.x.array
        y2_old.x.scatter_forward()

        w_ooold.x.array[:] = w_oold.x.array
        w_ooold.x.scatter_forward()

        w_oold.x.array[:] = w_old.x.array
        w_oold.x.scatter_forward()

        w_old.x.array[:] = w_inc.x.array
        w_old.x.scatter_forward()

        w_i.x.array[:] = w_inc.x.array
        w_i.x.scatter_forward()

        u_vis.x.array[:] = w_inc.x.array[map_u_]
        u_vis.x.scatter_forward()

        p_vis.x.array[:] = w_inc.x.array[map_p_]
        p_vis.x.scatter_forward()

        us1_vis.x.array[:] = y1_new.x.array[map_u_]
        us1_vis.x.scatter_forward()

        us2_vis.x.array[:] = y2_new.x.array[map_u_]
        us2_vis.x.scatter_forward()

        visco_out = project(Constant(mesh_, PETSc.ScalarType(m)), VisSpace_)
        visco_vis.x.array[:] = visco_out.x.array
        visco_vis.x.scatter_forward()

        if inte_xdmf > 0 and time + time_tol >= next_xdmf_time:
            ufile.write_function(u_vis, time)
            pfile.write_function(p_vis, time)
            us1file.write_function(us1_vis, time)
            us2file.write_function(us2_vis, time)
            vfile.write_function(visco_vis, time)

            mpi_print(f"  XDMF saved at t = {time:g}")
            next_xdmf_time += inte_xdmf

        if inte_snap > 0 and time + time_tol >= next_bp_time:
            comm.Barrier()

            adios4dolfinx.write_function(
                RESULTS_BP,
                u_vis,
                time=time,
                name="u",
                engine="BP4",
            )
            adios4dolfinx.write_function(
                RESULTS_BP,
                p_vis,
                time=time,
                name="p",
                engine="BP4",
            )
            adios4dolfinx.write_function(
                RESULTS_BP,
                visco_vis,
                time=time,
                name="viscosity",
                engine="BP4",
            )
            adios4dolfinx.write_function(
                RESULTS_BP,
                us1_vis,
                time=time,
                name="velocity_subscale1",
                engine="BP4",
            )
            adios4dolfinx.write_function(
                RESULTS_BP,
                us2_vis,
                time=time,
                name="velocity_subscale2",
                engine="BP4",
            )

            mpi_print(f"  BP snapshot saved at t = {time:g}")
            next_bp_time += inte_snap

        if L2_error_u < tolSteady and it == 1:
            mpi_print("  Steady solution reached.")
            break

        step += 1
        time += dt_

    ufile.close()
    pfile.close()
    us1file.close()
    us2file.close()
    vfile.close()


