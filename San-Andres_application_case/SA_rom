def create_actuator_disk_indicator(mesh_, ct_):
    """Create a DG0 indicator field for the actuator-disk region."""

    V0 = functionspace(mesh_, ("DG", 0))

    chi = Function(V0)
    chi.name = "chi_actuator_disk"
    chi.x.array[:] = 0.0

    disk_cells = ct_.find(DISK_MARKER)

    for cell in disk_cells:
        dofs = V0.dofmap.cell_dofs(cell)
        chi.x.array[dofs] = PETSc.ScalarType(1.0)

    chi.x.scatter_forward()

    n_local = len(disk_cells)
    n_global = comm.allreduce(n_local, op=MPI.SUM)

    mpi_print("Actuator disk indicator created.")
    mpi_print(f"  disk marker = {DISK_MARKER}")
    mpi_print(f"  local/global disk cells = {n_local}/{n_global}")

    if rank == 0 and n_global == 0:
        print(
            "WARNING: No cells were found for the actuator-disk marker. "
            "Check the cell tags in the mesh or basis file."
        )

    return chi


