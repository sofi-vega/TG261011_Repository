def detect_inlet_height(mesh_):
    """Detect the vertical extent of the inlet boundary."""

    x_coords = mesh_.geometry.x[:, 0]
    y_coords = mesh_.geometry.x[:, 1]

    x_min_local = np.min(x_coords)
    x_min = comm.allreduce(x_min_local, op=MPI.MIN)

    tol = 1.0e-8 * max(1.0, abs(x_min))
    mask = np.isclose(x_coords, x_min, atol=tol)

    if np.any(mask):
        y_min_local = np.min(y_coords[mask])
        y_max_local = np.max(y_coords[mask])
    else:
        y_min_local = np.min(y_coords)
        y_max_local = np.max(y_coords)

    y_min = comm.allreduce(y_min_local, op=MPI.MIN)
    y_max = comm.allreduce(y_max_local, op=MPI.MAX)

    mpi_print("Inlet height diagnostic:")
    mpi_print(f"  y_min_inlet = {y_min}")
    mpi_print(f"  y_max_inlet = {y_max}")
    mpi_print(f"  inlet height = {y_max - y_min}")

    return y_min, y_max


