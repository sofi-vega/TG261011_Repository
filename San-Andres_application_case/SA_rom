def try_read_mesh(paths):
    """Read the mesh from the first available BP4 source."""

    last_error = None

    for path in paths:
        try:
            mesh_ = adios4dolfinx.read_mesh(path, comm, engine="BP4")
            mpi_print(f"Mesh read from: {path}")
            return mesh_, path

        except Exception as exc:
            last_error = exc
            mpi_print(f"Could not read mesh from {path}: {exc}")

    raise RuntimeError(
        "Could not read the mesh from any source. Check BASIS_BP and MESH_BP."
    ) from last_error


def try_read_meshtags(mesh_, tag_name, paths):
    """Read mesh tags from the first available BP4 source."""

    last_error = None

    for path in paths:
        try:
            tags = adios4dolfinx.read_meshtags(
                path,
                mesh_,
                meshtag_name=tag_name,
                engine="BP4",
            )
            tags.name = tag_name

            mpi_print(f"{tag_name} read from: {path}")
            return tags

        except Exception as exc:
            last_error = exc
            mpi_print(f"Could not read {tag_name} from {path}: {exc}")

    raise RuntimeError(
        f"Could not read {tag_name}. Check BASIS_BP or mesh/mesh.bp."
    ) from last_error


